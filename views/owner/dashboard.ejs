<% layout('layouts/ownerBoilerplate') -%>

<div class="owner-dashboard">

    <div class="dashboard-header">

        <h1 class="dashboard-title">
            OWNER DASHBOARD
        </h1>

        <a
            href="/owner/bookings"
            class="btn btn-outline-success history-btn"
        >
            View Booking History
        </a>

    </div>

    <div class="stats-grid">

        <div class="dashboard-stat-card">

            <h6>Total Turfs</h6>

            <div class="stat-number">
                <%= turfs.length %>
            </div>

        </div>

        <div class="dashboard-stat-card">

            <h6>Today's Bookings</h6>

            <div class="stat-number">
                <%= bookings.length %>
            </div>

        </div>

    </div>

    <section class="dashboard-section">

        <h2 class="section-title">
            Today's Bookings
        </h2>

        <% if(bookings.length === 0){ %>

            <div class="empty-state">
                No bookings for today.
            </div>

        <% } %>

        <% for(let booking of bookings){ %>

            <div class="booking-history-card">

                <div>
                    <h4>
                        <%= booking.turf.name %>
                    </h4>

                    <p>
                        <i class="fa-solid fa-user"></i>
                        <%= booking.user.username %>
                    </p>
                </div>

                <div class="booking-info">

                    <span>
                        <%= booking.slot %>
                    </span>

                    <span class="booking-date">
                        <%= booking.date %>
                    </span>

                </div>

            </div>

        <% } %>

    </section>

    <section class="dashboard-section">

        <h2 class="section-title">
            My Turfs
        </h2>

        <div class="owner-turf-grid">

            <% for(let turf of turfs){ %>

                <div class="owner-turf-card">

                    <h3>
                        <%= turf.name %>
                    </h3>

                    <p>
                        <%= turf.location %>
                    </p>

                    <div class="owner-actions">

                        <a
                            href="/turfs/<%= turf._id %>"
                            class="btn btn-success"
                        >
                            View
                        </a>

                        <a
                            href="/owner/<%= turf._id %>/edit"
                            class="btn btn-outline-success"
                        >
                            Edit
                        </a>

                        <a
                            href="/owner/<%= turf._id %>/delete"
                            class="btn btn-outline-danger"
                        >
                            Delete
                        </a>

                    </div>

                </div>

            <% } %>

        </div>

    </section>

</div>