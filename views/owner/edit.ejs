<% layout('layouts/ownerBoilerplate') -%>

<div class="container-new py-5">

    <div class="login-card mx-auto p-4">

        <h1
            class="text-center mb-4"
            style="color:#1db954;font-family:Anton;"
        >
            Edit TURF
        </h1>

        <form action="/owner/<%= turf._id %>" method="POST" enctype="multipart/form-data">

            <div class="mb-3">
                <label class="form-label">
                    Turf Name
                </label>

                <input
                    type="text"
                    name="turf[name]"
                    class="form-control"
                    value="<%= turf.name %>"
                    required
                >
            </div>

            <div class="mb-3">
                <label class="form-label">
                    Location
                </label>

                <input
                    type="text"
                    name="turf[location]"
                    class="form-control "
                    value="<%= turf.location %>"
                >
            </div>

            <div class="mb-3">
                <label class="form-label">
                    Price Per Hour (₹)
                </label>

                <input
                    type="number"
                    name="turf[price]"
                    class="form-control "
                    value="<%= turf.price %>"
                    min="0"
                >
            </div>

            <div class="mb-3">
                <label class="form-label">
                    Upload New Image
                </label>


                <input
                    type="file"
                    name="turf[image]"
                    class="form-control "
                    
                    
                >

            </div>

            <div class="mb-4">
                <label class="form-label">
                    Description
                </label>

                <textarea
                    name="turf[description]"
                    rows="5"
                    class="form-control "
                    required
                ><%= turf.description %></textarea>
            </div>

            <button
                class="btn btn-success w-100 login-btn"
                type="submit"
            >
                Apply Changes
            </button>

        </form>

    </div>

</div>