                </ul>

            </a>

            <a href="/owner/dashboard" class="role-card owner">

                <div class="role-icon owner-icon">
                    <i class="fa-solid fa-building"></i>
                </div>

                <h2>I'M A TURF OWNER</h2>

                <p>
                    Manage bookings, availability, pricing and grow your business.
                </p>

                <ul>
                    <li>✓ Manage turfs</li>
                    <li>✓ Track bookings</li>
                    <li>✓ Revenue insights</li>
                </ul>

            </a>

        </div>

    </div>

</section>