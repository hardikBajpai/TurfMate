<% layout('layouts/boilerplate') -%>

<section class="home-hero">

    <div class="hero-content">

        <div class="welcome-pill">
            ● WELCOME TO TURFMATE
        </div>

        <h1 class="hero-title">
            HOW WILL YOU
            <br>
            USE <span>TURFMATE?</span>
        </h1>

        <p class="hero-subtitle">
            Find the perfect turf for your next match or manage your own sports facility.
        </p>

        <div class="role-container">

            <a href="/turfs" class="role-card player">

