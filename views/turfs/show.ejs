<% layout('layouts/boilerplate') -%>

<div class="container-fluid py-4">

    <!-- Turf Image -->
    <div class="row mb-4">

        <div class="col-12">

            <img
                src="<%= turf.image.url %>"
                class="img-fluid turf-image w-100"
                alt="turf-image"
            >

        </div>

    </div>

    <!-- Main Content -->
    <div class="row g-4">

        <!-- LEFT SECTION -->
        <div class="col-12 col-lg-8">

            <div class="data-details">

                <div class="intro mb-4">

                    <h1 class="turf-title">
                        <%= turf.name %>
                    </h1>

                    <p class="text-secondary">
                        <i class="fa-solid fa-location-dot"></i>
                        <%= turf.location %>
                        
                    </p>
                    <a
    href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(turf.location) %>"
    target="_blank"
    class="btn btn-outline-success"
>
    <i class="fa-solid fa-location-dot"></i>
    Open in Google Maps
</a>

                </div>

                <div class="description">

                    <h5>ABOUT THIS TURF</h5>

                    <p>
                        <%= turf.description %>
                    </p>

                </div>

                <hr>

                <!-- Review Form -->

                <h4
                    style="
                    color:#1db954;
                    font-family:Anton;
                    "
                >
                    Leave a Review
                </h4>

                <div class="review-form">

                    <form
                        action="/turfs/<%= turf._id %>/reviews"
                        method="POST"
                        novalidate
                        class="needs-validation"
                    >

                        <label
                            class="form-label"
                            for="rating"
                        >
                            Rating
                        </label>

                        <fieldset class="starability-slot">
  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>

                        <div class="mb-3">

                            <label
                                class="form-label"
                                for="comment"
                            >
                                Comment
                            </label>

                            <textarea
                                required
                                class="form-control"
                                id="comment"
                                name="review[comment]"
                                rows="5"
                            ></textarea>

                            <div class="invalid-feedback">
                                Please Add Some Comment For Review
                            </div>

                        </div>

                        <button
                            class="btn btn-outline-light"
                        >
                            Submit
                        </button>

                    </form>

                </div>

                <hr>

                <!-- Reviews -->

                <% if(turf.reviews.length > 0){ %>

                    <h4
                        style="
                        color:#1db954;
                        font-family:Anton;
                        "
                    >
                        All Reviews
                    </h4>

                <% } %>

                <div class="row g-3">

                    <% for(review of turf.reviews){ %>

                        <div class="col-12 col-md-6">

                            <div class="card-review h-100">

                                <div class="card-body-review">

                                    <h6>
                                        @<%= review.author.username %>
                                    </h6>

                                    <p class="starability-result" data-rating="<%= review.rating %>">
                                    </p>

                                    <p>
                                        <%= review.comment %>
                                    </p>

                            
  

                                    <form
                                        action="/turfs/<%= turf._id %>/reviews/<%= review._id %>?_method=DELETE"
                                        method="POST"
                                    >

                                        <button
                                            class="btn btn-outline-light"
                                        >
                                            Delete
                                        </button>

                                    </form>

                                </div>

                            </div>

                        </div>

                    <% } %>

                </div>

            </div>

        </div>

        <!-- RIGHT SECTION -->

        <div class="col-12 col-lg-4">

            <div class="book-details p-1">

                <div class="book-price">

                    <h1>

                        <span style="color:#1db954;">

                            ₹ <%= turf.price.toLocaleString("en-IN") %>

                        </span>

                    </h1>

                    <p>/ hour</p>

                    <hr>

                </div>

                <h4 class="mb-3">
                    CHECK AVAILABILITY
                </h4>

                <form
                    action="/turfs/<%= turf._id %>/slots"
                    method="GET"
                >

                    <input
                        type="date"
                        class="form-control"
                        id="preferDate"
                        name="date"
                        min="<%= new Date().toISOString().split('T')[0] %>"
                        required
                    >

                    <button
                        type="submit"
                        class="btn btn-success w-100 mt-3"
                    >
                        FIND SLOTS
                    </button>

                </form>

                <% if(selectedDate){ %>

                    <hr>

                    <form
                        id="slots-section"
                        action="/turfs/<%= turf._id %>/book"
                        method="POST"
                    >

                        <input
                            type="hidden"
                            name="date"
                            value="<%= selectedDate %>"
                        >

                        <div class="slot-grid">

                            <% for(let slot of allSlots){ %>

    <%
        const startTime = slot.split(" - ")[0];

        const slotDateTime = moment(
            `${selectedDate} ${startTime}`,
            "YYYY-MM-DD hh:mm A"
        );

        const isPast =
            slotDateTime.isBefore(moment());

        const isBooked =
            bookedSlots.includes(slot);
    %>

    <% if(isBooked){ %>

        <label class="slot-card booked">
            <span>
                <%= slot %> (Booked)
            </span>
        </label>

    <% } else if(isPast){ %>

        <label class="slot-card booked">
            <span>
                <%= slot %> (Expired)
            </span>
        </label>

    <% } else { %>

        <label class="slot-card">

            <input
                type="checkbox"
                class="slot-checkbox"
                name="slots"
                value="<%= slot %>"
                data-price="<%= turf.price %>"
            >

            <span>
                <%= slot %>
            </span>

        </label>

    <% } %>

<% } %>

                        </div>

                        <div class="price-summary mt-3">

                            <h3>

                                Total :

                                <span id="totalPrice">
                                    0
                                </span>

                                ₹

                            </h3>

                        </div>

                        <button
                            type="submit"
                            class="btn btn-success w-100 mt-3"
                        >
                            Book Now
                        </button>
                        

                    </form>

                <% } %>

            </div>

        </div>

    </div>

</div>

<script>

document.addEventListener(
    "DOMContentLoaded",
    () => {

        const checkboxes =
            document.querySelectorAll(
                ".slot-checkbox"
            );

        const totalPrice =
            document.getElementById(
                "totalPrice"
            );

        checkboxes.forEach(
            (checkbox) => {

                checkbox.addEventListener(
                    "change",
                    () => {

                        let total = 0;

                        checkboxes.forEach(
                            (cb) => {

                                if(cb.checked){

                                    total += Number(
                                        cb.dataset.price
                                    );

                                }

                            }
                        );

                        if(totalPrice){

                            totalPrice.textContent =
                                total.toLocaleString(
                                    "en-IN"
                                );

                        }

                    }
                );

            }
        );

    }
);

</script>