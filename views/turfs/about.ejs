<% layout('layouts/boilerplate') -%>
<div class="hero-about">
<section class="hero">
    <div class="content">
        <p class="content-first">OUR STORY</p>
        <div class="content-center">
             <div>BUILT FOR <br><span style="color:#1db954">CRICKET</span> <br>LOVERS</div>
        </div>
         <div class="content-last">
           TurfMate was born from a simple frustration — booking a cricket turf<br> shouldn't need a dozen phone calls. I am building the easiest way <br>to find, book, and play. 
         </div>
    </div>
</section>

<div class="working">

    <div class="working-first">HOW IT WORKS</div>
    <div class="working-instruction">BOOK IN 3 SIMPLE STEPS </div>
    <div class="working-card">
        <div class="card" style="width: 18rem;">
  <div class="card-body">
     <h6 class="card-subtitle mb-2 text-muted">01</h6>
    <h5 class="card-title text-success">Browse Turf</h5>
   
    <p class="card-text custom-para-card">Explore turf listings in your city. Filter by availability, location, type, or amenities to find your perfect ground.</p>
  </div>
</div>

<div class="card" style="width: 18rem;">
  <div class="card-body">
    <h6 class="card-subtitle mb-2 text-muted">02</h6>
    <h5 class="card-title text-success">Pick a Slot</h5>

    <p class="card-text custom-para-card">Choose your preferred date and time from the real-time availability calendar. No calls, no waiting — instant confirmation.</p>

  </div>
</div>

<div class="card" style="width: 18rem;">
  <div class="card-body">
    <h6 class="card-subtitle mb-2 text-muted ">03</h6>
    <h5 class="card-title text-success">Play</h5>
   
    <p class="card-text custom-para-card">Show up and play. Your booking details are saved in your account. Cancel up to 2 hours before if plans change.
</p>

  </div>
</div>
    </div>


</div>
</div>

<div style="display: flex;justify-content: center; margin-bottom: 2rem; height:8rem;align-items: center;">
   <form action="/turfs">
     <button type="submit" class="btn btn-lg btn-success">BROWSE TURF</button>
   </form>
</div>

