<% layout('layouts/boilerplate') -%>

<div class="container mt-5">

    <h1 class="booking-heading">
        MY BOOKINGS
    </h1>

    <% const validBookings = bookings.filter(booking => booking.turf); %>
    <% const now = new Date(new Date().toLocaleString("en-US", { timeZone: "Asia/Kolkata" })); %>

    <% if(validBookings.length === 0){ %>

        <div class="empty-bookings">
            <h4>No bookings found</h4>
            <p>Book a turf and it will appear here.</p>

            <a href="/turfs" class="btn btn-success">
                Explore Turfs
            </a>
        </div>

    <% } else { %>

        <div class="booking-container">

            <% validBookings.forEach(booking => { %>

                <%
                    let isPastBooking = false;

                    try {
                        const bookingDateTime = new Date(new Date(booking.date).toLocaleString("en-US", { timeZone: "Asia/Kolkata" }));

                        if (booking.slot) {
                            const slotParts = booking.slot.split(" - ");

                            if (slotParts.length > 1) {
                                const endTime = slotParts[1];

                                const [time, meridian] = endTime.split(" ");

                                let [hours, minutes] = time.split(":").map(Number);

                                if (meridian === "PM" && hours !== 12) {
                                    hours += 12;
                                }

                                if (meridian === "AM" && hours === 12) {
                                    hours = 0;
                                }

                                bookingDateTime.setHours(hours);
                                bookingDateTime.setMinutes(minutes);
                                bookingDateTime.setSeconds(0);
                                bookingDateTime.setMilliseconds(0);

                                isPastBooking = bookingDateTime < now;
                            }
                        }
                    } catch (err) {
                        isPastBooking = false;
                    }
                %>

                <div class="booking-card">

                    <img
                        src="<%= booking.turf.image.url %>"
                        alt="<%= booking.turf.name %>"
                        class="booking-image"
                    >

                    <div class="booking-content">

                        <h3>
                            <%= booking.turf.name %>
                        </h3>

                        <p>
                            <i class="fa-solid fa-location-dot"></i>
                            <%= booking.turf.location %>
                        </p>

                        <hr>

                        <p>
                            <strong>Date:</strong>
                            <%= booking.date %>
                        </p>

                        <p>
                            <strong>Slot:</strong>
                            <%= booking.slot %>
                        </p>

                        <p>
                            <strong>Price:</strong>
                            ₹<%= booking.turf.price %>
                        </p>

                        <p>
                            <strong>Status:</strong>

                            <% if(booking.status === "booked"){ %>
                                <span class="status-booked">
                                    Booked
                                </span>
                            <% } else { %>
                                <span class="status-cancelled">
                                    Cancelled
                                </span>
                            <% } %>

                        </p>

                        <% if(booking.status === "booked"){ %>

                            <% if(isPastBooking){ %>

                                <form
                                    action="/turfs/bookings/<%= booking._id %>?_method=DELETE"
                                    method="POST"
                                >
                                    <button
                                        type="submit"
                                        class="btn btn-danger w-100"
                                        onclick="return confirm('Delete this booking permanently?')"
                                    >
                                        Delete Booking
                                    </button>
                                </form>

                            <% } else { %>

                                <form
                                    action="/turfs/bookings/<%= booking._id %>/cancel?_method=PUT"
                                    method="POST"
                                >
                                    <button
                                        type="submit"
                                        class="btn btn-outline-danger w-100"
                                        onclick="return confirm('Cancel this booking?')"
                                    >
                                        Cancel Booking
                                    </button>
                                </form>

                            <% } %>

                        <% } else { %>

                            <form
                                action="/turfs/bookings/<%= booking._id %>/cancel?_method=PUT" method="POST"
                            >
                                <button
                                    type="submit"
                                    class="btn btn-danger w-100"
                                    onclick="return confirm('Delete this booking permanently?')"
                                >
                                    Delete Booking
                                </button>
                            </form>

                        <% } %>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } %>

</div>